# ==============================================================================
# TwinPix Workspace Environment Variables
# ==============================================================================
# Copy this file to .env and replace placeholders with your actual secrets.
# NEVER commit the actual .env file to version control.

# ------------------------------------------------------------------------------
# 1. Database (Neon / PostgreSQL)
# ------------------------------------------------------------------------------
# Connection string for Prisma. Use the pooled connection URL in serverless environments.
DATABASE_URL="postgres://user:password@hostname/dbname?pgbouncer=true"

# ------------------------------------------------------------------------------
# 2. Authentication (Auth.js / NextAuth)
# ------------------------------------------------------------------------------
# Used to encrypt session JWTs. Generate a secure string: `openssl rand -base64 32`
NEXTAUTH_SECRET="your-super-secret-32-character-string"
# Base URL of the application. Required for Vercel production deployments.
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 3. External Services
# ------------------------------------------------------------------------------

# Apify (Instagram Scraper)
# API Token for running Apify actors
APIFY_API_TOKEN="apify_api_your_token_here"

# OpenAI (Copilot & Insights)
# API Key for generating SWOT analysis and brand matching
OPENAI_API_KEY="sk-proj-your_openai_api_key_here"
# Optional: Override the default model (e.g., gpt-4o, gpt-3.5-turbo)
OPENAI_MODEL="gpt-4o-mini"

# Cloudinary (Asset Storage)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL="cloudinary://123456789:abcdefghijklmnop@your_cloud_name"

# ------------------------------------------------------------------------------
# 4. Application Config
# ------------------------------------------------------------------------------
# Current environment (development, staging, production)
NODE_ENV="development"
